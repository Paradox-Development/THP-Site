RewriteEngine On

# Disable directory browsing
Options -Indexes

# Custom 404 error page
ErrorDocument 404 /404.html

# Handle /blog specifically - serve blog.html when /blog is requested
RewriteRule ^blog/?$ blog.html [L]

# Redirect index.html to directory
RewriteCond %{THE_REQUEST} ^GET\ /(.*)index\.html(\?[^\s]*)?\ HTTP
RewriteRule (.*)index\.html$ /$1 [R=301,L]

# Redirect .html to clean URL
RewriteCond %{THE_REQUEST} ^GET\ /(.*)\.html(\?[^\s]*)?\ HTTP
RewriteRule (.*)\.html$ /$1 [R=301,L]

# Serve .html files for clean URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.html [NC,L]